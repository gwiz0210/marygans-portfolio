---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudyNav from "../../components/CaseStudyNav.astro";
import ProjectIcon from "../../components/ProjectIcon.astro";
import { PROJECT_ICON_OVERRIDES } from "../../content/featuredProjects";

export async function getStaticPaths() {
  const caseStudies = await getCollection("case-studies");

  return caseStudies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const heroDescription = study.data.tagline || study.data.blurb || study.data.overview || "";
const pageBackground = study.data.pageBackgroundColor ?? study.data.lightColor ?? "var(--bg)";
const heroTextColor = study.data.darkColor ?? "var(--ink)";
const iconName = PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id];
const metadataItems = [
  { label: "Role", value: study.data.role },
  { label: "Team", value: study.data.team },
  { label: "Timeline", value: study.data.time },
  { label: "Tools", value: study.data.tools ?? study.data.deliverable },
].filter((item) => item.value);
---

<BaseLayout title={`${study.data.title} | Mary Gans`}>
  <section class="project-hero" style={`background:${pageBackground};`}>
    <div class="page-shell">
      <div class="hero-title">
        {iconName ? (
          <ProjectIcon name={iconName} />
        ) : (
          <span class="hero-emoji">{study.data.emoji}</span>
        )}
        <h1 style={`color:${heroTextColor};`}>{study.data.title}</h1>
      </div>
      {heroDescription && <p class="hero-description" style={`color:${heroTextColor};`}>{heroDescription}</p>}
      {metadataItems.length > 0 && (
        <div class="meta-grid" style={`color:${heroTextColor};`}>
          {metadataItems.map((item) => (
            <div class="meta-item">
              <div class="meta-label">{item.label}</div>
              <div class="meta-value">{item.value}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <div class="page-shell">
    <div class="project-content card">
      <main class="richtext">
        <Content />
      </main>
    </div>
  </div>

  <CaseStudyNav />

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button type="button" class="lightbox-close" aria-label="Close image">&times;</button>
    <img class="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<script>
  function initLightbox() {
    const lightbox = document.querySelector<HTMLDivElement>(".lightbox");
    const lightboxImg = document.querySelector<HTMLImageElement>(".lightbox-img");
    const closeBtn = document.querySelector<HTMLButtonElement>(".lightbox-close");
    if (!lightbox || !lightboxImg || !closeBtn) return;

    const open = (src: string, alt: string) => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.add("is-open");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      lightbox.classList.remove("is-open");
      lightbox.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      lightboxImg.src = "";
    };

    document.querySelectorAll<HTMLImageElement>(".richtext img").forEach((img) => {
      img.classList.add("is-zoomable");
      img.addEventListener("click", () => open(img.currentSrc || img.src, img.alt));
    });

    lightbox.addEventListener("click", (event) => {
      if (event.target === lightbox) close();
    });
    closeBtn.addEventListener("click", close);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });
  }

  initLightbox();
</script>

<style>
  .project-hero {
    padding: 48px 0 40px;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .hero-title {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin: 12px 0;
  }

  .hero-emoji {
    font-size: 40px;
  }

  .hero-title :global(.project-icon) {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    margin-top: 6px;
    color: #f39a00;
  }

  .project-hero h1 {
    font-size: 34px;
    margin: 0;
  }

  .hero-description {
    font-size: 17px;
    max-width: 640px;
    line-height: 1.5;
    opacity: 0.85;
  }

  .meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 24px;
  }

  .meta-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.6;
  }

  .meta-value {
    font-size: 14px;
    font-weight: 600;
    margin-top: 4px;
  }

  .project-content {
    max-width: 780px;
    margin: -20px auto 60px;
    padding: 40px;
  }

  .richtext :global(h2),
  .richtext :global(h3),
  .richtext :global(h4) {
    margin: 32px 0 12px;
    scroll-margin-top: 32px;
  }

  .richtext :global(p) {
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 16px;
  }

  .richtext :global(img) {
    border-radius: var(--radius-md);
    margin: 20px 0;
  }

  .richtext :global(img.is-zoomable) {
    cursor: zoom-in;
    transition: opacity 0.15s ease;
  }

  .richtext :global(img.is-zoomable:hover) {
    opacity: 0.92;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    background: rgba(20, 18, 16, 0.9);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    border-radius: var(--radius-md);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    cursor: zoom-out;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  @media (max-width: 640px) {
    .lightbox {
      padding: 16px;
    }

    .lightbox-close {
      top: 12px;
      right: 12px;
    }
  }

  .richtext :global(ul),
  .richtext :global(ol) {
    color: var(--ink-soft);
    line-height: 1.7;
    padding-left: 20px;
  }

  .richtext :global(hr) {
    border: 0;
    border-top: 1px solid rgba(43, 43, 43, 0.08);
    margin: 24px 0;
  }

  @media (max-width: 640px) {
    .project-content {
      padding: 24px;
      margin-top: -12px;
    }
  }
</style>
