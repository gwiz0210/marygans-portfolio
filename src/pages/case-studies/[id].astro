---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudyNav from "../../components/CaseStudyNav.astro";

export async function getStaticPaths() {
  const caseStudies = await getCollection("case-studies");

  return caseStudies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const heroDescription = study.data.tagline || study.data.blurb || study.data.overview || "";
const pageBackground = study.data.pageBackgroundColor ?? study.data.lightColor ?? "var(--bg)";
const heroTextColor = study.data.darkColor ?? "var(--ink)";
const metadataItems = [
  { label: "Role", value: study.data.role },
  { label: "Team", value: study.data.team },
  { label: "Timeline", value: study.data.time },
  { label: "Tools", value: study.data.tools ?? study.data.deliverable },
].filter((item) => item.value);
---

<BaseLayout title={`${study.data.title} | Mary Gans`}>
  <section class="project-hero" style={`background:${pageBackground};`}>
    <div class="page-shell">
      <span class="hero-emoji">{study.data.emoji}</span>
      <h1 style={`color:${heroTextColor};`}>{study.data.title}</h1>
      {heroDescription && <p class="hero-description" style={`color:${heroTextColor};`}>{heroDescription}</p>}
      {metadataItems.length > 0 && (
        <div class="meta-grid" style={`color:${heroTextColor};`}>
          {metadataItems.map((item) => (
            <div class="meta-item">
              <div class="meta-label">{item.label}</div>
              <div class="meta-value">{item.value}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <div class="page-shell">
    <div class="project-content card">
      <main class="richtext">
        <Content />
      </main>
    </div>
  </div>

  <CaseStudyNav />
</BaseLayout>

<style>
  .project-hero {
    padding: 48px 0 40px;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .hero-emoji {
    font-size: 40px;
  }

  .project-hero h1 {
    font-size: 34px;
    margin: 12px 0 12px;
  }

  .hero-description {
    font-size: 17px;
    max-width: 640px;
    line-height: 1.5;
    opacity: 0.85;
  }

  .meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 24px;
  }

  .meta-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.6;
  }

  .meta-value {
    font-size: 14px;
    font-weight: 600;
    margin-top: 4px;
  }

  .project-content {
    max-width: 780px;
    margin: -20px auto 60px;
    padding: 40px;
  }

  .richtext :global(h2),
  .richtext :global(h3),
  .richtext :global(h4) {
    margin: 32px 0 12px;
    scroll-margin-top: 32px;
  }

  .richtext :global(p) {
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0 0 16px;
  }

  .richtext :global(img) {
    border-radius: var(--radius-md);
    margin: 20px 0;
  }

  .richtext :global(ul),
  .richtext :global(ol) {
    color: var(--ink-soft);
    line-height: 1.7;
    padding-left: 20px;
  }

  .richtext :global(hr) {
    border: 0;
    border-top: 1px solid rgba(43, 43, 43, 0.08);
    margin: 24px 0;
  }

  @media (max-width: 640px) {
    .project-content {
      padding: 24px;
      margin-top: -12px;
    }
  }
</style>
