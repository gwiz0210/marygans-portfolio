---
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoCard from "../components/BentoCard.astro";
---

<BaseLayout
  title="About me - Mary Gansallo"
  description="Hi! I'm Mary. I'm a Product Designer based in the DC area, and I specialize in design systems. Feel free to reach out if you have any questions or want to talk design."
>
  <div class="page-shell">
    <div class="about-grid">
      <BentoCard colSpan={2} rowSpan={2} class="about-bio">
        <h1>Hi! 👋🏽</h1>
        <p>
          I embrace experimentation and strive to make the world a better
          place through design.
        </p>
        <p>
          💡 <strong>Solving the tricky stuff.</strong> As a systems thinker, I
          love breaking down complex problems, especially when it comes to
          design systems and generative AI.
        </p>
        <p>
          💻 <strong>Background.</strong> My Computer Science background fuels
          my empathy and passion for developer experiences.
        </p>
        <p>
          🔧 <strong>Figma geek.</strong> I use Figma to build anything from low
          and high fidelity wireframes to rapid prototypes, plugins, and
          design systems.
        </p>
        <p>
          🤜🏾 <strong>Team player.</strong> I thrive in collaborative,
          cross-functional teams where empathy, data, and creativity intersect
          to create intuitive product experiences.
        </p>
        <p>
          ⚽ <strong>Fun.</strong> I play and watch soccer and flag football.
          I'm an Airbnb host, so I also enjoy investing in real estate,
          travel, music, and building things!
        </p>
      </BentoCard>

      <BentoCard colSpan={1} rowSpan={1} class="about-photo">
        <img
          src="/images/44DBC6E8-F292-484C-B7B5-DBDCB6D9EF69.jpeg"
          alt="Mary Gansallo headshot"
        />
      </BentoCard>

      <BentoCard colSpan={1} rowSpan={1} background="var(--accent-blue)" class="about-actions">
        <a href="https://www.linkedin.com/in/mary-gansallo/" target="_blank" rel="noopener" class="action-button">
          Connect on LinkedIn
        </a>
        <a href="/documents/MaryGans-Resume-Latest.pdf" target="_blank" rel="noopener" class="action-button action-button--ghost">
          Download resume
        </a>
      </BentoCard>
    </div>
  </div>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(200px, auto);
    gap: var(--gap);
    margin-top: 8px;
  }

  :global(.about-bio) {
    grid-column: 2 / span 2 !important;
    grid-row: 1 / span 2 !important;
  }

  :global(.about-photo) {
    grid-column: 1 !important;
    grid-row: 1 !important;
  }

  :global(.about-actions) {
    grid-column: 1 !important;
    grid-row: 2 !important;
  }

  :global(.about-bio) h1 {
    font-size: 28px;
    margin-bottom: 8px;
  }

  :global(.about-bio) p {
    margin: 0 0 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  :global(.about-bio) p:last-child {
    margin-bottom: 0;
  }

  :global(.about-photo) {
    padding: 0;
    align-items: stretch;
  }

  :global(.about-photo) img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  :global(.about-actions) {
    justify-content: center;
    gap: 20px;
  }

  .action-button {
    display: block;
    text-align: center;
    padding: 16px 20px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--surface);
    font-weight: 600;
    font-size: 14px;
  }

  .action-button--ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--ink);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    :global(.about-bio),
    :global(.about-photo),
    :global(.about-actions) {
      grid-column: auto !important;
      grid-row: auto !important;
    }
  }
</style>
