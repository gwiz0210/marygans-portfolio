---
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoCard from "../components/BentoCard.astro";
---

<BaseLayout
  title="About me - Mary Gansallo"
  description="Hi! I'm Mary, a product designer exploring how AI is changing the way we build software."
>
  <div class="page-shell">
    <div class="about-grid">
      <BentoCard colSpan={2} rowSpan={2} class="about-bio">
        <h1>Hi! 👋🏽</h1>
        <p>
          I'm Mary, a product designer exploring how AI is changing the way we
          build software.
        </p>
        <p>
          Over the past several years, I've designed enterprise products at
          Microsoft, helping teams transform complex security, identity, and AI
          capabilities into experiences people can understand and trust.
        </p>
        <p>
          Today, I'm particularly interested in:
        </p>
        <ul>
          <li>Designing Agentic UX</li>
          <li>Building AI-native product workflows</li>
          <li>Rapid prototyping with AI</li>
          <li>Design systems for autonomous experiences</li>
          <li>Turning ideas into working products as quickly as possible</li>
        </ul>
        <p>
          I believe the best designers of the next decade won't just create
          interfaces. They'll design systems where humans and AI work together
          effectively.
        </p>
        <p>
          Outside of work, I'm usually building side projects, investing in
          real estate, coaching soccer, cycling, traveling, or documenting my
          experiments on LinkedIn and Substack.
        </p>
      </BentoCard>

      <BentoCard colSpan={1} rowSpan={1} class="about-photo">
        <img
          src="/images/44DBC6E8-F292-484C-B7B5-DBDCB6D9EF69.jpeg"
          alt="Mary Gansallo headshot"
        />
      </BentoCard>

      <BentoCard colSpan={1} rowSpan={1} background="var(--accent-blue)" class="about-actions">
        <a href="https://www.linkedin.com/in/mary-gansallo/" target="_blank" rel="noopener" class="action-button">
          Connect on LinkedIn
        </a>
        <a href="/documents/MaryGans-Resume-Latest.pdf" target="_blank" rel="noopener" class="action-button action-button--ghost">
          Download resume
        </a>
      </BentoCard>
    </div>
  </div>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(200px, auto);
    gap: var(--gap);
    margin-top: 8px;
  }

  :global(.about-bio) {
    grid-column: 2 / span 2 !important;
    grid-row: 1 / span 2 !important;
  }

  :global(.about-photo) {
    grid-column: 1 !important;
    grid-row: 1 !important;
  }

  :global(.about-actions) {
    grid-column: 1 !important;
    grid-row: 2 !important;
  }

  :global(.about-bio) h1 {
    font-size: 28px;
    margin-bottom: 8px;
  }

  :global(.about-bio) p {
    margin: 0 0 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  :global(.about-bio) p:last-child {
    margin-bottom: 0;
  }

  :global(.about-bio) ul {
    margin: 0 0 14px;
    padding-left: 22px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  :global(.about-bio) li {
    margin: 0 0 6px;
  }

  :global(.about-bio) li::marker {
    color: var(--ink-soft);
  }

  :global(.about-photo) {
    padding: 0;
    align-items: stretch;
  }

  :global(.about-photo) img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  :global(.about-actions) {
    justify-content: center;
    gap: 20px;
  }

  .action-button {
    display: block;
    text-align: center;
    padding: 16px 20px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--surface);
    font-weight: 600;
    font-size: 14px;
  }

  .action-button--ghost {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--ink);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    :global(.about-bio),
    :global(.about-photo),
    :global(.about-actions) {
      grid-column: auto !important;
      grid-row: auto !important;
    }
  }
</style>
