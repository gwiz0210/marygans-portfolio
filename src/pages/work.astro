---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoCard from "../components/BentoCard.astro";
import ProjectIcon from "../components/ProjectIcon.astro";
import { FEATURED_PROJECT_SLUGS, PROJECT_MOCKUP_TILT_OVERRIDES, PROJECT_ICON_OVERRIDES } from "../content/featuredProjects";

const allStudies = await getCollection("case-studies");

const studyBySlug = new Map(
  allStudies
    .filter((study) => study.data.draft !== true)
    .map((study) => [study.data.slug ?? study.id, study]),
);

const studies = FEATURED_PROJECT_SLUGS
  .map((slug) => studyBySlug.get(slug))
  .filter((study): study is NonNullable<typeof study> => Boolean(study));

const mockupTiltClass = (study: (typeof studies)[number], i: number) =>
  PROJECT_MOCKUP_TILT_OVERRIDES[study.data.slug ?? study.id] ??
  (i % 2 === 0 ? "mockup-bleed--a" : "mockup-bleed--b");
---

<BaseLayout title="Work - Mary Gansallo" description="Case studies and projects by Mary Gansallo.">
  <div class="page-shell">
    <h1 class="page-title">Selected work</h1>
    <div class="work-grid">
      {studies.map((study, i) => (
        <BentoCard
          href={`/case-studies/${study.data.slug ?? study.id}`}
          colSpan={1}
          rowSpan={1}
          background={study.data.lightColor}
          color={study.data.darkColor}
          padding="0"
          arrow
          class="project-card"
        >
          <div class="project-copy">
            <div class="project-title">
              {PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id] ? (
                <ProjectIcon name={PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id]} />
              ) : (
                <span class="project-emoji">{study.data.emoji}</span>
              )}
              <h3>{study.data.title}</h3>
            </div>
            <p>{study.data.tagline ?? study.data.blurb}</p>
            {study.data.role && <p class="role">{study.data.role}</p>}
          </div>
          {study.data.laptopMockup && (
            <img
              src={study.data.laptopMockup}
              alt={study.data.title}
              class:list={["mockup-bleed", mockupTiltClass(study, i)]}
            />
          )}
        </BentoCard>
      ))}

    </div>
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 32px;
    margin: 8px 0 20px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 340px;
    gap: var(--gap);
  }

  :global(.project-card) {
    position: relative;
    min-height: 0;
  }

  :global(.project-card) {
    background: rgba(251, 250, 247, 0.62) !important;
    color: var(--ink) !important;
    border: 1px solid rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .project-copy {
    position: relative;
    z-index: 2;
    padding: 22px;
    max-width: 90%;
  }

  .project-title {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 4px;
  }

  .project-emoji {
    display: block;
    font-size: 20px;
  }

  .project-copy :global(.project-icon) {
    display: block;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: #f39a00;
  }

  .mockup-bleed {
    position: absolute;
    z-index: 1;
    width: var(--mockup-width, 72%);
    max-width: none;
    height: auto;
    object-fit: contain;
    object-position: center bottom;
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.22);
    left: 50%;
    right: auto;
    bottom: var(--mockup-bottom, -12%);
    transform: translateX(-50%);
    transition: transform 0.25s ease;
  }

  .mockup-bleed--a {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--b {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--fluent {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--catalog {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--coraway {
    --mockup-width: 72%;
    --mockup-bottom: -27%;
    mix-blend-mode: multiply;
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.22));
    box-shadow: none;
  }

  .mockup-bleed--ai-dashboard {
    --mockup-width: 72%;
    --mockup-bottom: -8%;
  }

  .mockup-bleed--perception {
    --mockup-width: 72%;
    --mockup-bottom: -2%;
  }

  .mockup-bleed--identity-access-graph {
    --mockup-width: 72%;
    --mockup-bottom: -5%;
  }

  :global(.project-card):hover .mockup-bleed {
    transform: translateX(-50%) scale(1.04);
  }

  .project-copy h3 {
    font-size: 17px;
    margin: 0;
  }

  .project-copy p {
    font-size: 13px;
    margin: 0;
    opacity: 0.85;
  }

  .project-copy .role {
    margin-top: 6px;
    font-weight: 600;
    opacity: 0.7;
  }

  @media (max-width: 900px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
