---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoCard from "../components/BentoCard.astro";
import ProjectIcon from "../components/ProjectIcon.astro";
import { FEATURED_PROJECT_SLUGS, PROJECT_MOCKUP_TILT_OVERRIDES, PROJECT_ICON_OVERRIDES } from "../content/featuredProjects";

const allStudies = await getCollection("case-studies");
const studies = allStudies
  .filter((study) => study.data.draft !== true)
  .sort((a, b) => {
    const orderA = a.data.order;
    const orderB = b.data.order;
    if (orderA == null && orderB == null) return 0;
    if (orderA == null) return 1;
    if (orderB == null) return -1;
    return orderA - orderB;
  });

const studyBySlug = new Map(studies.map((study) => [study.data.slug ?? study.id, study]));
const featuredStudies = FEATURED_PROJECT_SLUGS.map(slug => studyBySlug.get(slug)).filter(Boolean);

const mockupTiltClass = (study: (typeof studies)[number], i: number) =>
  PROJECT_MOCKUP_TILT_OVERRIDES[study.data.slug ?? study.id] ??
  (i % 2 === 0 ? "mockup-bleed--a" : "mockup-bleed--b");

const posts = [
  {
    title: "Your AI Spinner Is Lying to You",
    blurb: "Designing AI that feels trustworthy before the answer arrives.",
    date: "Jul 5",
    url: "https://uxinbeta.substack.com/p/your-ai-spinner-is-lying-to-you",
    image:
      "https://substackcdn.com/image/fetch/$s_!Zh7v!,w_1200,h_675,c_fill,f_jpg,q_auto:good,fl_progressive:steep,g_auto/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fd4cf43a5-c05c-43ec-95f8-34db0a191993_1600x900.png",
    imageZoom: true,
  },
  {
    title: "What happens when you teach AI to see design patterns?",
    blurb: "How I built a system that observes UX so I don't have to screenshot forever.",
    date: "Oct 14, 2025",
    url: "https://uxinbeta.substack.com/p/what-happens-when-you-teach-ai-to",
    image:
      "https://substackcdn.com/image/fetch/$s_!ilHL!,w_1200,h_675,c_fill,f_jpg,q_auto:good,fl_progressive:steep,g_auto/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F25ba3b27-01d5-40a6-8d38-228fea51e291_500x500.png",
  },
];
---

<BaseLayout title="Mary Gansallo • Portfolio">
  <div class="page-shell">
    <section id="hero" class="hero-section" aria-label="Intro">
      <div class="hi-animation" aria-hidden="true">
        <lottie-player
          src="https://uploads-ssl.webflow.com/6014d63282f72c94d8863ebb/601799207cad0917720e287c_hi.json"
          background="transparent"
          speed="1"
          autoplay
        ></lottie-player>
      </div>
      <div class="hero-container">
        <div class="hero-text">
          <h1 class="welcome-statement">👋🏽 Hey, I'm Mary</h1>
          <div class="personal-tagline">
            I
            <span data-delete-delay="3000" data-delay="150" data-words="design,develop" data-colors="orange" class="typer">design</span><span id="first-typer" data-owner="first-typer" class="cursor"></span>&nbsp;AI experiences with empathy & expertise.
          </div>
          <div class="personal-tagline subtitle">
            Agentic UX // Enterprise systems // AI-driven products 🎈<br /><br />&lt; Frontend dev /&gt;
          </div>
        </div>
      </div>
    </section>

    <div class="bento-grid">
      <h2 class="section-heading">Featured Projects</h2>

      <div class="project-row project-row--top">
        {featuredStudies.slice(0, 3).map((study, i) => (
          <BentoCard
            href={`/case-studies/${study.data.slug ?? study.id}`}
            background={study.data.lightColor}
            color={study.data.darkColor}
            padding="0"
            draggable
            arrow
            class="project-card"
          >
            <div class="project-copy">
              <div class="project-title">
                {PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id] ? (
                  <ProjectIcon name={PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id]} />
                ) : (
                  <span class="project-emoji">{study.data.emoji}</span>
                )}
                <h3>{study.data.title}</h3>
              </div>
              <p>{study.data.tagline ?? study.data.blurb}</p>
            </div>
            {study.data.laptopMockup && (
              <img
                src={study.data.laptopMockup}
                alt={study.data.title}
                class:list={["mockup", "mockup-bleed", mockupTiltClass(study, i)]}
              />
            )}
          </BentoCard>
        ))}
      </div>

      <div class="project-row project-row--second">
        {featuredStudies.slice(3).map((study, i) => (
          <BentoCard
            href={`/case-studies/${study.data.slug ?? study.id}`}
            background={study.data.lightColor}
            color={study.data.darkColor}
            padding="0"
            draggable
            arrow
            class="project-card"
          >
            <div class="project-copy">
              <div class="project-title">
                {PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id] ? (
                  <ProjectIcon name={PROJECT_ICON_OVERRIDES[study.data.slug ?? study.id]} />
                ) : (
                  <span class="project-emoji">{study.data.emoji}</span>
                )}
                <h3>{study.data.title}</h3>
              </div>
              <p>{study.data.tagline ?? study.data.blurb}</p>
            </div>
            {study.data.laptopMockup && (
              <img
                src={study.data.laptopMockup}
                alt={study.data.title}
                class:list={["mockup", "mockup-bleed", mockupTiltClass(study, i + 3)]}
              />
            )}
          </BentoCard>
        ))}
      </div>

      <h2 class="section-heading">A bit about me</h2>

      <div class="about-row">
        <BentoCard href="/about-me" colSpan={2} rowSpan={2} draggable arrow class="intro-card">
          <p class="status-pill">🟢 Open to new projects</p>
          <div class="intro-heading">
            <img
              src="/images/44DBC6E8-F292-484C-B7B5-DBDCB6D9EF69.jpeg"
              alt="Mary Gansallo"
              class="avatar"
            />
            <h1>Hi, I'm Mary, a product designer & frontend dev.</h1>
          </div>
          <p class="bio">
            Based in the DC area, I specialize in design systems, enterprise
            design, and AI-driven products. I love breaking down complex
            problems where empathy, data, and creativity intersect.
          </p>
        </BentoCard>

        <BentoCard colSpan={1} rowSpan={1} background="var(--accent-yellow)" draggable class="fact-card">
          <span class="fact-emoji">⚽</span>
          <p class="fact-text">
            Airbnb host, soccer player, and real-estate tinkerer outside of
            design.
          </p>
        </BentoCard>

        <BentoCard
          href="https://www.linkedin.com/in/mary-gansallo/"
          external
          colSpan={1}
          rowSpan={1}
          background="var(--accent-blue)"
          draggable
          arrow
          class="link-card"
        >
          <span class="link-icon-wrap" aria-hidden="true">
            <img src="/images/linkedIn-logo.svg" alt="" class="brand-icon" />
          </span>
          <p>LinkedIn</p>
        </BentoCard>

        <BentoCard
          href="/documents/Mary-Gansallo-Resume.pdf"
          external
          colSpan={1}
          rowSpan={1}
          background="var(--accent-yellow)"
          draggable
          arrow
          class="link-card"
        >
          <span class="link-emoji">📋</span>
          <p>Resume</p>
        </BentoCard>

        <BentoCard
          href="https://github.com/gwiz0210"
          external
          colSpan={1}
          rowSpan={1}
          background="var(--accent-lilac)"
          draggable
          arrow
          class="link-card"
        >
          <span class="link-icon-wrap" aria-hidden="true">
            <img src="/images/github-logo.svg" alt="" class="brand-icon" />
          </span>
          <p>GitHub</p>
        </BentoCard>
      </div>

      <div class="quick-links-row">
        <BentoCard
          href="https://open.spotify.com/playlist/37i9dQZF1E4uYtkbmCDcgE?si=nizOA58sSayR6ESQUgFg_g"
          external
          colSpan={1}
          rowSpan={1}
          background="var(--accent-mint)"
          draggable
          arrow
          class="link-card"
        >
          <span class="link-icon-wrap" aria-hidden="true">
            <img src="/images/spotify-logo.svg" alt="" class="brand-icon" />
          </span>
          <p>Spotify</p>
          <p class="link-subtext">What I've been listening to these days</p>
        </BentoCard>

        <BentoCard
          href="https://calendly.com/mary-gansallo"
          external
          colSpan={1}
          rowSpan={1}
          background="var(--accent-pink)"
          draggable
          arrow
          class="link-card"
        >
          <span class="link-emoji">📅</span>
          <p>Book a call with me</p>
        </BentoCard>

        <BentoCard href="/my-process" colSpan={1} rowSpan={1} background="var(--accent-yellow)" draggable arrow class="link-card">
          <span class="link-emoji">🛣️</span>
          <p>My approach</p>
          <p class="link-subtext">How I take a project from discovery through release.</p>
        </BentoCard>
      </div>

      <h2 class="section-heading">Writing</h2>

      <div class="posts-row">
        {posts.map((post) => (
          <BentoCard
            href={post.url}
            external
            padding="0"
            arrow
            class="post-card"
          >
            <div class="post-image-wrap">
              <img
                src={post.image}
                alt=""
                class:list={["post-image", { "post-image--zoom": post.imageZoom }]}
              />
            </div>
            <div class="post-copy">
              <h3>{post.title}</h3>
              <p>{post.blurb}</p>
              <p class="post-date">{post.date} · UX in Beta</p>
            </div>
          </BentoCard>
        ))}
      </div>

      <BentoCard colSpan={4} rowSpan={1} draggable class="loop-card">
        <div class="loop-copy">
          <h3>Want to stay in the loop?</h3>
          <p>
            Notes on design systems, AI-driven product work, and lessons from
            the field, over on UX in Beta.
          </p>
        </div>
        <a
          href="https://uxinbeta.substack.com"
          target="_blank"
          rel="noopener"
          class="loop-cta"
        >
          Subscribe <span aria-hidden="true">↗</span>
        </a>
      </BentoCard>
    </div>
  </div>
</BaseLayout>

<style>
  :global(body) {
    background: #f1f1f1;
    color: #5c5c5c;
  }

  .hero-section {
    position: relative;
    left: 50%;
    width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
    min-height: clamp(500px, 92vh, 760px);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    background: #f1f1f1;
    margin-top: 0;
    margin-bottom: clamp(52px, 8vw, 90px);
  }

  .hi-animation {
    position: absolute;
    z-index: 1;
    left: 50%;
    top: 50%;
    width: 100vw;
    height: 100%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hi-animation lottie-player {
    width: 100%;
    height: 100%;
    opacity: 0.95;
    mix-blend-mode: multiply;
    filter: sepia(0.34) saturate(1.28) hue-rotate(342deg) brightness(0.96) contrast(0.9);
    transform: scale(1.22);
  }

  .hero-container {
    position: relative;
    z-index: 3;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .welcome-statement {
    color: #5c5c5c;
    font-family: Poppins, sans-serif;
    font-size: clamp(40px, 4.2vw, 56px);
    font-weight: 500;
    line-height: 1.08;
    margin: 0;
    text-align: center;
  }

  .personal-tagline {
    color: #5c5c5c;
    text-align: left;
    margin-top: 25px;
    padding-left: 102px;
    font-family: Poppins, sans-serif;
    font-size: clamp(22px, 2.5vw, 34px);
    line-height: 1.2;
  }

  .personal-tagline.subtitle {
    color: #a3a3a3;
    text-align: center;
    margin: 40px 45px 0;
    padding-left: 100px;
    font-size: clamp(16px, 1.4vw, 22px);
    font-weight: 400;
    line-height: 1.35;
  }

  .typer {
    color: #f39a00;
    margin-left: 0.22em;
    font-weight: 500;
    display: inline-block;
  }

  .cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin: 0 0.16em;
    transform: translateY(0.16em);
    background: currentColor;
    animation: blink 0.95s steps(1, end) infinite;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .bento-grid {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-top: 0;
  }

  .about-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 150px;
    gap: var(--gap);
  }

  :global(.intro-card) {
    justify-content: center;
    gap: 12px;
  }

  .intro-heading {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .status-pill {
    display: inline-flex;
    align-self: flex-start;
    background: var(--accent-mint);
    color: var(--ink);
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 999px;
    margin: 0;
  }

  :global(.intro-card) h1 {
    font-size: 26px;
    line-height: 1.25;
    margin: 0;
  }

  .bio {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }

  :global(.fact-card) {
    justify-content: center;
    gap: 8px;
  }

  .fact-emoji {
    font-size: 28px;
  }

  .fact-text {
    margin: 0;
    font-size: 14px;
    color: var(--ink);
  }

  :global(.project-card) {
    position: relative;
    min-height: 0;
  }

  :global(.project-card),
  :global(.placeholder-card) {
    background: rgba(251, 250, 247, 0.62) !important;
    color: var(--ink) !important;
    border: 1px solid rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .project-copy {
    position: relative;
    z-index: 2;
    padding: 24px;
    max-width: 75%;
  }

  :global(.project-card--perception) .project-copy {
    max-width: 88%;
  }

  .project-title {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 4px;
  }

  .project-emoji {
    display: block;
    font-size: 20px;
  }

  .project-copy :global(.project-icon) {
    display: block;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: #f39a00;
  }

  .mockup-bleed {
    position: absolute;
    z-index: 1;
    width: var(--mockup-width, 72%);
    max-width: none;
    height: auto;
    object-fit: contain;
    object-position: center bottom;
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.22);
    left: 50%;
    right: auto;
    bottom: var(--mockup-bottom, -12%);
    transform: translateX(-50%);
    transition: transform 0.25s ease;
  }

  .mockup-bleed--a {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--b {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--fluent {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--catalog {
    --mockup-width: 72%;
    --mockup-bottom: -12%;
  }

  .mockup-bleed--coraway {
    --mockup-width: 72%;
    --mockup-bottom: -27%;
    mix-blend-mode: multiply;
    filter: drop-shadow(0 18px 30px rgba(0, 0, 0, 0.22));
    box-shadow: none;
  }

  .mockup-bleed--ai-dashboard {
    --mockup-width: 72%;
    --mockup-bottom: -8%;
  }

  .mockup-bleed--perception {
    --mockup-width: 72%;
    --mockup-bottom: -2%;
  }

  .mockup-bleed--identity-access-graph {
    --mockup-width: 72%;
    --mockup-bottom: -5%;
  }

  :global(.project-card):hover .mockup-bleed {
    transform: translateX(-50%) scale(1.04);
  }

  :global(.placeholder-card) {
    justify-content: center;
    gap: 10px;
  }

  :global(.placeholder-card) h3 {
    margin: 0;
    font-size: 16px;
    line-height: 1.25;
  }

  :global(.placeholder-card) p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 13px;
  }

  .project-copy h3 {
    font-size: 16px;
    margin: 0;
  }

  .project-copy p {
    font-size: 13px;
    margin: 0;
    opacity: 1;
    color: var(--ink-soft);
  }

  .section-heading {
    margin: 0;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .section-heading:not(:first-child) {
    margin-top: 28px;
  }

  :global(.link-card) {
    justify-content: flex-start;
    align-items: flex-start;
    gap: 8px;
  }

  :global(.link-card--wide) {
    flex-direction: row !important;
    align-items: center;
    gap: 14px;
  }

  .link-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .brand-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .link-emoji {
    display: block;
    font-size: 24px;
    line-height: 1;
  }

  :global(.link-card) p {
    margin: 0;
    font-weight: 600;
    font-size: 14px;
  }

  :global(.link-card) .link-subtext {
    margin-top: 2px;
    font-weight: 400;
    font-size: 13px;
    color: var(--ink-soft);
  }

  :global(.loop-card) {
    flex-direction: row !important;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .loop-copy h3 {
    font-size: 20px;
    margin: 0 0 6px;
  }

  .loop-copy p {
    font-size: 14px;
    margin: 0;
    color: var(--ink-soft);
    max-width: 520px;
  }

  .loop-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--surface);
    font-weight: 600;
    font-size: 14px;
  }

  .loop-cta:hover {
    opacity: 0.9;
  }

  .posts-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 310px;
    gap: var(--gap);
  }

  :global(.post-card) {
    display: flex;
    flex-direction: column;
  }

  .post-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
  }

  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-image--zoom {
    transform: scale(1.3);
    transform-origin: 50% 40%;
  }

  .post-copy {
    padding: 16px;
  }

  .post-copy h3 {
    font-size: 15px;
    line-height: 1.35;
    margin: 0 0 6px;
  }

  .post-copy p {
    font-size: 13px;
    color: var(--ink-soft);
    margin: 0;
  }

  .post-date {
    margin-top: 10px !important;
    font-size: 12px !important;
    opacity: 0.7;
  }

  .project-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 310px;
    gap: var(--gap);
  }

  .project-row :global(.bento-card) {
    grid-column: auto !important;
    grid-row: auto !important;
    height: 100%;
  }

  .quick-links-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 150px;
    gap: var(--gap);
  }

  .quick-links-row :global(.bento-card) {
    grid-column: auto !important;
    grid-row: auto !important;
    height: 100%;
  }

  @media (max-width: 900px) {
    .personal-tagline {
      padding-left: 48px;
    }

    .personal-tagline.subtitle {
      padding-left: 36px;
      margin-left: 20px;
      margin-right: 20px;
    }

    .about-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .project-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .quick-links-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .hero-section {
      min-height: 72vh;
      margin-bottom: 38px;
    }

    .hi-animation {
      width: 100vw;
      height: 100%;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }

    .hi-animation lottie-player {
      transform: scale(1.34);
    }

    .welcome-statement {
      font-size: clamp(36px, 9vw, 48px);
    }

    .personal-tagline,
    .personal-tagline.subtitle {
      text-align: center;
      padding-left: 0;
      margin-left: 16px;
      margin-right: 16px;
    }

    .personal-tagline {
      margin-top: 18px;
      font-size: clamp(19px, 6vw, 30px);
      line-height: 1.28;
    }

    .personal-tagline.subtitle {
      margin-top: 20px;
      font-size: clamp(15px, 3.7vw, 20px);
    }

    .about-row {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .about-row :global(.bento-card) {
      grid-row: auto;
      min-height: 160px;
    }

    .project-row {
      grid-row: auto;
      grid-template-columns: 1fr;
      grid-auto-rows: 320px;
    }

    .mockup-bleed--coraway {
      --mockup-width: 50%;
    }

    .posts-row {
      grid-template-columns: 1fr;
    }

    .quick-links-row {
      grid-template-columns: 1fr;
    }

  }
</style>

<script type="module" src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

<script>
  function initTyper() {
    const typer = document.querySelector(".typer");
    if (!typer) return;

    const words = (typer.getAttribute("data-words") || "design,develop")
      .split(",")
      .map((word) => word.trim())
      .filter(Boolean);
    if (!words.length) return;

    const typingDelay = Number(typer.getAttribute("data-delay") || 130);
    const deleteDelay = Number(typer.getAttribute("data-delete-delay") || 2200);

    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function tick() {
      const currentWord = words[wordIndex % words.length];

      if (!isDeleting) {
        charIndex += 1;
      } else {
        charIndex -= 1;
      }

      typer.textContent = currentWord.slice(0, charIndex);

      if (!isDeleting && charIndex === currentWord.length) {
        isDeleting = true;
        window.setTimeout(tick, deleteDelay);
        return;
      }

      if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex += 1;
      }

      const stepDelay = isDeleting ? Math.max(typingDelay * 0.58, 45) : typingDelay;
      window.setTimeout(tick, stepDelay);
    }

    tick();
  }

  function getDirectChild(container: Element, el: Element | null): Element | null {
    while (el && el.parentElement !== container) {
      el = el.parentElement;
    }
    return el;
  }

  function initSortable(container: Element | null) {
    if (!container) return;
    let draggingEl: Element | null = null;

    container.addEventListener("dragstart", (e) => {
      const card = getDirectChild(container, e.target as Element);
      if (!card || card.getAttribute("draggable") !== "true") return;
      draggingEl = card;
      (e as DragEvent).dataTransfer?.setData("text/plain", "");
      if ((e as DragEvent).dataTransfer) (e as DragEvent).dataTransfer!.effectAllowed = "move";
      card.classList.add("is-dragging");
    });

    container.addEventListener("dragend", () => {
      draggingEl?.classList.remove("is-dragging");
      draggingEl = null;
    });

    container.addEventListener("dragover", (e) => {
      if (!draggingEl) return;
      e.preventDefault();
    });

    container.addEventListener("drop", (e) => {
      if (!draggingEl) return;
      e.preventDefault();
      const target = getDirectChild(container, e.target as Element);
      if (!target || target === draggingEl || target.getAttribute("draggable") !== "true") return;

      const placeholder = document.createComment("");
      draggingEl.before(placeholder);
      target.replaceWith(draggingEl);
      placeholder.replaceWith(target);
    });
  }

  initTyper();
  initSortable(document.querySelector(".bento-grid"));
  document.querySelectorAll(".project-row").forEach(initSortable);
</script>
