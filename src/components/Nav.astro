---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const links = [
  { href: "/", label: "home" },
  { href: "/work", label: "work" },
  { href: "/about-me", label: "about me" },
  { href: "/my-process", label: "approach" },
  { href: "/documents/Mary-Gansallo-Resume.pdf", label: "resume", external: true },
];
---

<div class="nav-sticky">
  <header class="nav">
    <a href="/" class="wordmark">
      <img src="/images/favicon.png" alt="" class="wordmark-icon" width="28" height="28" />
      marygans
    </a>

    <nav class="pills">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={["pill", { active: isActive(link.href) }]}
            {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions" style="display:none">
      <a href="/documents/Mary-Gansallo-Resume.pdf" target="_blank" rel="noopener" class="nav-link">
        resume
      </a>
    </div>
  </header>
</div>

<script>
  const navSticky = document.querySelector(".nav-sticky");
  if (navSticky) {
    const updateScrolledState = () => {
      navSticky.classList.toggle("is-scrolled", window.scrollY > 8);
    };
    updateScrolledState();
    window.addEventListener("scroll", updateScrolledState, { passive: true });
  }
</script>

<style>
  .nav-sticky {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    box-shadow: none;
    transition: background 0.2s ease, box-shadow 0.2s ease, backdrop-filter 0.2s ease;
  }

  .nav-sticky.is-scrolled {
    background: rgba(243, 239, 233, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 rgba(43, 43, 43, 0.06), 0 8px 24px rgba(43, 43, 43, 0.05);
  }

  .nav {
    max-width: 1180px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    position: relative;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: var(--ink);
  }

  .wordmark-icon {
    display: block;
  }

  .pills {
    display: flex;
    align-items: center;
    gap: 4px;
    background: rgba(251, 250, 247, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 999px;
    padding: 6px;
    box-shadow: var(--shadow-card);
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .pill {
    padding: 8px 18px;
    border-radius: 999px;
    font-size: 14px;
    color: var(--ink-soft);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .pill:hover {
    color: var(--ink);
  }

  .pill.active {
    background: var(--ink);
    color: var(--surface);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 14px;
  }

  .nav-link--emphasis {
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .nav {
      flex-wrap: wrap;
      justify-content: center;
      padding-top: 20px;
    }

    .pills {
      position: static;
      left: auto;
      transform: none;
      order: 3;
      width: 100%;
      justify-content: center;
      flex-wrap: nowrap;
      gap: 0;
      padding: 5px;
    }

    .pill {
      padding: 7px 6px;
      font-size: 11px;
      white-space: nowrap;
    }

    .nav-actions {
      gap: 14px;
    }
  }
</style>
